# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/budgetnest?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=30d

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Secret key to protect the /api/cron/* trigger endpoints (used by an
# external scheduler like cron-job.org to run jobs on Render's free tier)
CRON_SECRET=change_this_to_a_long_random_string

# Email (used for signup/password-reset OTP codes)
# If left unset, OTP codes are logged to the server console instead of
# emailed — useful for local dev without real SMTP creds.
# Example for Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587,
# SMTP_USER=you@gmail.com, SMTP_PASS=<16-char App Password, not your login password>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="BudgetNest <no-reply@budgetnest.app>"
