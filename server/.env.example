# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/budgetnest?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=30d

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Secret key to protect the /api/cron/* trigger endpoints (used by an
# external scheduler like cron-job.org to run jobs on Render's free tier)
CRON_SECRET=change_this_to_a_long_random_string
